DATABASE_URL="postgresql://homestack:homestack@localhost:5432/homestack"
NEXTAUTH_SECRET="change-me-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials (used on first seed)
ADMIN_EMAIL="admin@homestack.local"
ADMIN_PASSWORD="homestack"

# Docker Compose — Postgres password
POSTGRES_PASSWORD="homestack"

# Docker Compose — host port (default 3000)
PORT=3000
